DATABASE_URL=postgresql://prayer_pwa:prayer_pwa@localhost:5432/prayer_pwa

# Public site URL — Cloudflare Tunnel hostname
# NEXT_PUBLIC_APP_URL=https://fortwayneprays.org

# Optional Planning Center API credentials (manual person-ID linking works without these)
# PLANNING_CENTER_APP_ID=
# PLANNING_CENTER_SECRET=

# Dev only: set to 0 to disable synthetic household candidates when PCO has no match
# ALLOW_PCO_LOGIN_FALLBACK=1

# YouVersion Platform app key — used to validate scripture refs and deep-link ESV on bible.com
# YOUVERSION_APP_KEY=
# YOUVERSION_ESV_VERSION_ID=59

# Optional notification providers (also configurable in Admin → Notifications)
# ELASTICEMAIL_API_KEY=
# ELASTICEMAIL_FROM_EMAIL=
# ELASTICEMAIL_FROM_NAME=Pray Like Crazy
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=+12605551212
# Login SMS OTP via Twilio Verify (VA... Service SID)
# TWILIO_VERIFY_SERVICE_SID=

# OpenAI API key for prayer-request Moderation API (omni-moderation-latest).
# Free moderations endpoint. Can also be set in Admin → Moderation.
# OPENAI_API_KEY=sk-...
