[Unit]
Description=Fort Wayne Prays (Next.js) — fortwayneprays.org
Documentation=https://fortwayneprays.org
After=network-online.target docker.service
Wants=network-online.target

[Service]
Type=simple
User=blackhawk
Group=blackhawk
WorkingDirectory=/home/blackhawk/prayer-pwa
Environment=NODE_ENV=production
Environment=PORT=3000
Environment=HOSTNAME=0.0.0.0
EnvironmentFile=-/home/blackhawk/prayer-pwa/.env.local
# Cloudflare Tunnel ingress: fortwayneprays.org → http://10.10.96.138:3000
ExecStartPre=/usr/bin/bash /home/blackhawk/prayer-pwa/deploy/prepare-standalone.sh
ExecStart=/usr/bin/node /home/blackhawk/prayer-pwa/.next/standalone/server.js
Restart=on-failure
RestartSec=5
TimeoutStartSec=60

[Install]
WantedBy=multi-user.target
